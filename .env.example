# =============================================================
# AssetFlow ERP - Environment Variables
# =============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ----- Database -----------------------------------------------
# PostgreSQL connection string
# Recommended: Use Neon (https://neon.tech) for serverless Postgres
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ----- NextAuth -----------------------------------------------
# A random secret used to sign/encrypt tokens
# Generate one with: openssl rand -hex 32
NEXTAUTH_SECRET="your-random-secret-here-minimum-32-characters"

# The canonical URL of your app
# Development: http://localhost:3000
# Production:  https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"
